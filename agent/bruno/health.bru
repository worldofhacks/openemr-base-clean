meta {
  name: Health
  type: http
  seq: 1
}

get {
  url: {{agent_base_url}}/health
  body: none
  auth: none
}

tests {
  test("liveness returns HTTP 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("liveness returns the process-only contract", function () {
    expect(res.getBody().status).to.equal("alive");
    expect(res.getBody().sha).to.be.a("string").and.not.be.empty;
  });

  test("liveness carries a correlation id", function () {
    expect(res.getHeader("x-copilot-request-id")).to.be.a("string").and.not.be.empty;
  });
}
