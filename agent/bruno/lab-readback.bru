meta {
  name: Source and artifact readback verification
  type: http
  seq: 7
}

get {
  url: {{agent_base_url}}/documents/{{lab_document_id}}/readback-verification?session_id={{session_id}}
  body: none
  auth: none
}

tests {
  test("source and artifact fresh reads match their SHA-256 digests", function () {
    expect(res.getStatus()).to.equal(200);
    const body = res.getBody();
    expect(body.source.algorithm).to.equal("sha256");
    expect(body.source.verified).to.equal(true);
    expect(body.artifact.algorithm).to.equal("sha256");
    expect(body.artifact.verified).to.equal(true);
  });
}

settings {
  encodeUrl: true
  timeout: 180000
}
