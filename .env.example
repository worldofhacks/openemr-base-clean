# ============================================================================
# OpenEMR application-level variables (from upstream)
# ============================================================================
# Possible options are prod or dev. No spaces, no quotes.
OPENEMR__ENVIRONMENT=
# Set to true to disable periodic background service execution (Ajax piggybacking).
# Session timeouts and notification badges remain active. Accepts true/1 or false/0.
OPENEMR__NO_BACKGROUND_TASKS=

# ============================================================================
# Deployment variables for this fork (names only — set real values in Railway
# service variables or your local shell; NEVER commit secrets).
#
# All names are consumed by the container entrypoint (docker/release/openemr.sh,
# reused verbatim by docker/railway/Dockerfile) or written into OpenEMR's
# globals table at boot (OPENEMR_SETTING_* handling in
# docker/release/utilities/devtoolsLibrary.source).
# See DEPLOYMENT.md for the full architecture and per-variable explanations.
# ============================================================================

# --- Database connection (Railway: reference the managed MySQL service) -----
# On Railway: MYSQL_HOST=${{MySQL.MYSQLHOST}}  (resolves to mysql.railway.internal)
MYSQL_HOST=
MYSQL_PORT=3306
# Root credentials are used ONCE at first boot to create the app database+user.
# On Railway: MYSQL_ROOT_PASS=${{MySQL.MYSQL_ROOT_PASSWORD}}
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASS=
# Application database user (created by the entrypoint at first boot)
MYSQL_USER=openemr
MYSQL_PASS=
MYSQL_DATABASE=openemr

# --- Initial OpenEMR admin bootstrap ----------------------------------------
# Set OE_PASS to a strong generated value so the instance NEVER runs with the
# well-known admin/pass default.
OE_USER=admin
OE_PASS=

# --- Railway/orchestration behavior -----------------------------------------
# REQUIRED on Railway: volumes mount empty, and SWARM_MODE=yes enables the
# entrypoint's restore of the sites/ template into the empty volume.
SWARM_MODE=yes

# --- OpenEMR globals set declaratively at boot (OPENEMR_SETTING_<global>) ---
# Enable REST + FHIR APIs (Administration -> Config -> Connectors equivalents)
OPENEMR_SETTING_rest_api=1
OPENEMR_SETTING_rest_fhir_api=1
# Public base URL of the deployment (required for OAuth2/FHIR)
OPENEMR_SETTING_site_addr_oath=
