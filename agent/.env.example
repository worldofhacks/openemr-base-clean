# Clinical Co-Pilot configuration inventory. Copy to `.env`, fill required values,
# then source it explicitly. The application never auto-loads this file.

# Exact deploy identity (the gated deploy workflow sets a 40-character SHA).
DEPLOYMENT_SHA=unknown

# OpenEMR and SMART launch. HTTPS is mandatory for OpenEMR URLs.
OPENEMR_FHIR_BASE_URL=https://openemr.example.invalid/apis/default/fhir
OPENEMR_OAUTH_BASE_URL=https://openemr.example.invalid/oauth2/default
OPENEMR_REST_BASE_URL=https://openemr.example.invalid/apis/default
SMART_CLIENT_ID=
SMART_CLIENT_SECRET=
AGENT_CALLBACK_URL=http://localhost:8000/callback
TOKEN_LIFETIME_SECONDS=3600

# Anthropic answer/extraction provider and bounded serving budgets.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=8192
LLM_TIMEOUT_SECONDS=90
LLM_MAX_TOOL_ITERATIONS=6
DAILY_COST_CAP_USD=5.0
FHIR_PER_CALL_TIMEOUT_SECONDS=8
TURN_TOTAL_BUDGET_SECONDS=30
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_TURN_CAP=20

# Durable Agent Postgres store.
SESSION_STORE_DSN=

# Week 2 document runtime. Keep disabled until the category, Binary-readback,
# route-registry, credential-vault, worker, and cutover attestations are complete.
W2_DOCUMENT_RUNTIME_ENABLED=false
SOURCE_DOCUMENT_PATH=/AI-Source-Documents
SOURCE_DOCUMENT_CATEGORY_ID=
SOURCE_DOCUMENT_CATEGORY_ACL=patients|docs
ARTIFACT_DOCUMENT_PATH=/AI-Extractions
ARTIFACT_DOCUMENT_CATEGORY_ID=
ARTIFACT_DOCUMENT_CATEGORY_ACL=patients|docs
OPENEMR_BINARY_READBACK_SAFE=false
# DOCUMENT_CREDENTIAL_KEY=<url-safe Fernet key; same protected value on web and worker>
DOCUMENT_WORKER_POLL_SECONDS=1.0
DOCUMENT_WORKER_LEASE_SECONDS=60
DOCUMENT_WORKER_MAX_ATTEMPTS=3
DOCUMENT_WORKER_BASE_BACKOFF_SECONDS=5
DOCUMENT_WORKER_ID=document-worker
AGENT_VERSION=0.1.0

# Graph/retrieval integration. CI is always local and must leave COHERE_API_KEY unset.
W2_GRAPH_ENABLED=0
RERANKER=local
# COHERE_API_KEY=<required only for an owner-approved production Cohere reranker>
# EVIDENCE_CORPUS_DIR=<optional absolute path; defaults to the committed corpus>

# Optional soft observability dependency. Exports are aggregate-only; clinical content is
# unconditionally redacted in code and has no environment override.
LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
