# Clinical Co-Pilot agent — configuration template (ARCHITECTURE.md §2, D3).
#
# Copy to `.env` (gitignored) and fill in real values. NEVER commit `.env`.
# Secrets live only here or in the platform's secret store — never in source.
#
# The app reads the process environment (config uses env_file=None), so source this
# file before running locally:   set -a; . .env; set +a
# On Railway the platform injects the same variables.

# --- OpenEMR (Zone A): read-only FHIR + OAuth surfaces (D9). Must be https (F-S.9). ---
OPENEMR_FHIR_BASE_URL=https://openemr-production-cc95.up.railway.app/apis/default/fhir
OPENEMR_OAUTH_BASE_URL=https://openemr-production-cc95.up.railway.app/oauth2/default

# --- SMART client (D2/D9): the registered, Co-Pilot-enabled OAuth client ---
SMART_CLIENT_ID=
SMART_CLIENT_SECRET=

# --- LLM provider (Zone C, D4). First real LLM spend starts at E5. ---
ANTHROPIC_API_KEY=sk-ant-...
# Primary model (D4). Sonnet 4.6 = cost/quality balance; Haiku 4.5 for utility.
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=2048
LLM_MAX_TOOL_ITERATIONS=6
# Small daily USD cost cap — a trip degrades to the deterministic D13 fallback,
# never an uncapped spend. In-process for the demo; prod needs a shared counter.
DAILY_COST_CAP_USD=5.0

# --- Session store (Postgres, D-O2 / §3a) ---
SESSION_STORE_DSN=

# --- Observability (Langfuse Cloud, D5 rev 2026-07-08) — optional soft dep (§6/§7) ---
LANGFUSE_HOST=https://us.cloud.langfuse.com
# Keep deployed keys in Railway's agent-service secret variables. These entries document names
# only; never copy a real public/secret key into this tracked template.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# D16 (pending owner finalize sign-off): content is separate from required accountability
# metadata. Default off; enable only for the Synthea-only demo after explicit owner approval.
# Real-PHI use stays off unless the D5 production controls and separate risk acceptance exist.
LANGFUSE_LOG_CONTENT=false
